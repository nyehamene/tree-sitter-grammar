{
  "name": "grammar",
  "word": "identifier",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "production_definition"
      }
    },
    "production_definition": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "TOKEN",
          "content": {
            "type": "STRING",
            "value": ":"
          }
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "_production"
          },
          "named": true,
          "value": "body"
        },
        {
          "type": "TOKEN",
          "content": {
            "type": "STRING",
            "value": ";"
          }
        }
      ]
    },
    "_production": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "option"
          },
          {
            "type": "SYMBOL",
            "name": "repeatition"
          },
          {
            "type": "SYMBOL",
            "name": "group"
          },
          {
            "type": "SYMBOL",
            "name": "alternative"
          },
          {
            "type": "SYMBOL",
            "name": "_terminal"
          },
          {
            "type": "SYMBOL",
            "name": "_nonterminal"
          }
        ]
      }
    },
    "option": {
      "type": "SEQ",
      "members": [
        {
          "type": "ALIAS",
          "content": {
            "type": "FIELD",
            "name": "open",
            "content": {
              "type": "STRING",
              "value": "["
            }
          },
          "named": false,
          "value": "open"
        },
        {
          "type": "SYMBOL",
          "name": "_production"
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "FIELD",
            "name": "close",
            "content": {
              "type": "STRING",
              "value": "]"
            }
          },
          "named": false,
          "value": "close"
        }
      ]
    },
    "repeatition": {
      "type": "SEQ",
      "members": [
        {
          "type": "ALIAS",
          "content": {
            "type": "FIELD",
            "name": "open",
            "content": {
              "type": "STRING",
              "value": "{"
            }
          },
          "named": false,
          "value": "open"
        },
        {
          "type": "SYMBOL",
          "name": "_production"
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "FIELD",
            "name": "close",
            "content": {
              "type": "STRING",
              "value": "}"
            }
          },
          "named": false,
          "value": "close"
        }
      ]
    },
    "group": {
      "type": "SEQ",
      "members": [
        {
          "type": "ALIAS",
          "content": {
            "type": "FIELD",
            "name": "open",
            "content": {
              "type": "STRING",
              "value": "("
            }
          },
          "named": false,
          "value": "open"
        },
        {
          "type": "SYMBOL",
          "name": "_production"
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "FIELD",
            "name": "close",
            "content": {
              "type": "STRING",
              "value": ")"
            }
          },
          "named": false,
          "value": "close"
        }
      ]
    },
    "alternative": {
      "type": "PREC_RIGHT",
      "value": 2,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "FIELD",
            "name": "left",
            "content": {
              "type": "SYMBOL",
              "name": "_production"
            }
          },
          {
            "type": "ALIAS",
            "content": {
              "type": "STRING",
              "value": "|"
            },
            "named": false,
            "value": "separator"
          },
          {
            "type": "FIELD",
            "name": "right",
            "content": {
              "type": "SYMBOL",
              "name": "_production"
            }
          }
        ]
      }
    },
    "_terminal": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "regexp"
        }
      ]
    },
    "string": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "FIELD",
            "name": "open",
            "content": {
              "type": "STRING",
              "value": "\""
            }
          },
          {
            "type": "PATTERN",
            "value": "[^\"]*"
          },
          {
            "type": "FIELD",
            "name": "close",
            "content": {
              "type": "STRING",
              "value": "\""
            }
          }
        ]
      }
    },
    "regexp": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "FIELD",
            "name": "open",
            "content": {
              "type": "STRING",
              "value": "/"
            }
          },
          {
            "type": "PATTERN",
            "value": "[^//]*"
          },
          {
            "type": "FIELD",
            "name": "close",
            "content": {
              "type": "STRING",
              "value": "/"
            }
          }
        ]
      }
    },
    "_nonterminal": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "identifier"
        }
      ]
    },
    "identifier": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "FIELD",
                "name": "open",
                "content": {
                  "type": "STRING",
                  "value": "$"
                }
              },
              {
                "type": "BLANK"
              }
            ]
          },
          {
            "type": "PATTERN",
            "value": "[a-z][A-Za-z_0-9]*"
          }
        ]
      }
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "FIELD",
            "name": "open",
            "content": {
              "type": "STRING",
              "value": "//"
            }
          },
          {
            "type": "PATTERN",
            "value": "[^\\n]*"
          },
          {
            "type": "STRING",
            "value": "\n"
          }
        ]
      }
    }
  },
  "extras": [
    {
      "type": "SYMBOL",
      "name": "comment"
    },
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": []
}
