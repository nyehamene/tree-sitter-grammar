{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "grammar",
      "camelcase": "Grammar",
      "title": "Grammar",
      "scope": "source.grammar",
      "file-types": [
        "grammar"
      ],
      "injection-regex": "^grammar$",
      "class-name": "TreeSitterGrammar",
      "highlights": "queries/highlights.scm",
      "locals": "queries/locals.scm",
      "tags": "queries/tags.scm"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Grammar grammar for tree-sitter",
    "authors": [
      {
        "name": "hnyehamene",
        "email": "nhcdeveloper@gmail.com"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-grammar"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}
